# ─── Frontend .env.local (copy to frontend/.env.local) ────────────────────
# URL of your FastAPI backend (Railway/Render URL in production)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Your deployed frontend URL (used for OG/canonical)
NEXT_PUBLIC_SITE_URL=https://pdfforge.app

# ─── Backend .env (copy to backend/.env) ──────────────────────────────────
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,https://pdfforge.app,https://www.pdfforge.app

# ─── Notes ────────────────────────────────────────────────────────────────
# For Vercel: add NEXT_PUBLIC_API_URL in the Vercel dashboard under
#   Project → Settings → Environment Variables
#   Value: https://your-app.up.railway.app  (or your Render URL)
#
# For Railway: these env vars are set in the Railway dashboard.
#   ALLOWED_ORIGINS should include your Vercel URL.
